---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Company Info -->
      <div>
        <h3 class="text-xl font-bold font-heading mb-4">Mallik Group PLC</h3>
        <p class="text-gray-300 mb-4">
          A diversified business group committed to excellence across multiple industries.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold font-heading mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-300 hover:text-secondary transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-300 hover:text-secondary transition-colors">About Us</a></li>
          <li><a href="/chairman" class="text-gray-300 hover:text-secondary transition-colors">Chairman Message</a></li>
          <li><a href="/news" class="text-gray-300 hover:text-secondary transition-colors">News</a></li>
          <li><a href="/contact" class="text-gray-300 hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <!-- Companies -->
      <div>
        <h4 class="text-lg font-semibold font-heading mb-4">Our Companies</h4>
        <ul class="space-y-2">
          <li><a href="/companies/immigration" class="text-gray-300 hover:text-secondary transition-colors">Mallik Immigration Ltd</a></li>
          <li><a href="/companies/properties" class="text-gray-300 hover:text-secondary transition-colors">Mallik Properties Ltd</a></li>
          <li><a href="/companies/enterprise" class="text-gray-300 hover:text-secondary transition-colors">Messrs Mallik Enterprise</a></li>
          <li><a href="/companies/education" class="text-gray-300 hover:text-secondary transition-colors">Mallik Education Network</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-700 mt-8 pt-8 text-center">
      <p class="text-gray-400">&copy; {currentYear} Mallik Group PLC. All rights reserved.</p>
    </div>
  </div>
</footer>
