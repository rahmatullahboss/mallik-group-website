---
interface Props {
  name: string;
  description: string;
  href: string;
}

const { name, description, href } = Astro.props;
---

<a 
  href={href}
  class="block bg-white/5 backdrop-blur-md border border-white/20 rounded-2xl p-6 transition-all duration-300 ease-out hover:-translate-y-2 hover:shadow-2xl hover:shadow-black/20 group"
>
  <h3 class="text-xl font-bold text-white font-heading mb-3">
    {name}
  </h3>
  <p class="text-gray-300 mb-6 font-body">
    {description}
  </p>
  <span class="text-secondary font-semibold flex items-center group-hover:underline">
    Learn More 
    <svg class="w-4 h-4 ml-1 transform transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
  </span>
</a>
