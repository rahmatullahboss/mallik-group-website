---
const megaMenuServices = [
  { 
    intent: 'I need immigration help', 
    company: 'Mallik Immigration Ltd',
    desc: 'Visa, Work Permit, Citizenship',
    href: '/companies/immigration',
    icon: `<svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`
  },
  { 
    intent: 'I want to buy property', 
    company: 'Mallik Properties Ltd',
    desc: 'Real Estate, Investment, Management',
    href: '/companies/properties',
    icon: `<svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`
  },
  { 
    intent: 'I need business solutions', 
    company: 'Messrs Mallik Enterprise',
    desc: 'Enterprise Development, Strategy',
    href: '/companies/enterprise',
    icon: `<svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`
  },
  { 
    intent: 'I want quality education', 
    company: 'Mallik Education Network',
    desc: 'Training, Courses, Leadership',
    href: '/companies/education',
    icon: `<svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>`
  }
];
---

<header class="bg-white/95 backdrop-blur-md shadow-sm sticky top-0 z-50 border-b border-gray-100 transition-all duration-300" id="main-header">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group">
        <span class="text-2xl font-black text-primary font-heading tracking-tight group-hover:text-secondary transition-colors">Mallik Group PLC</span>
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-2 h-full">
        <a href="/" class="nav-link">Home</a>
        <a href="/about" class="nav-link">About</a>
        
        <!-- Services Mega Menu Trigger -->
        <div class="group h-full flex items-center relative">
          <button class="nav-link flex items-center gap-1 group-hover:text-secondary" aria-expanded="false" aria-haspopup="true">
            Our Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <!-- Mega Menu Panel -->
          <div class="absolute top-[80px] left-1/2 -translate-x-1/2 w-[800px] bg-white rounded-b-2xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top -translate-y-2 group-hover:translate-y-0 p-8 grid grid-cols-2 gap-6 z-50">
            {megaMenuServices.map((service) => (
              <a href={service.href} class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors group/item">
                <div class="mt-1 bg-primary/5 p-3 rounded-lg group-hover/item:bg-primary/10 transition-colors">
                  <Fragment set:html={service.icon} />
                </div>
                <div>
                  <p class="font-heading font-bold text-primary text-lg mb-1 group-hover/item:text-secondary transition-colors">{service.intent}</p>
                  <p class="text-sm text-gray-500 font-medium">{service.company}</p>
                  <p class="text-xs text-gray-400 mt-1">{service.desc}</p>
                </div>
              </a>
            ))}
            <div class="col-span-2 mt-4 pt-4 border-t border-gray-100 flex justify-between items-center">
              <p class="text-sm text-gray-500 font-medium">Not sure what you need?</p>
              <a href="/contact" class="text-sm font-bold text-secondary hover:text-primary transition-colors">Contact our advisors &rarr;</a>
            </div>
          </div>
        </div>

        <a href="/chairman" class="nav-link">Chairman</a>
        <a href="/news" class="nav-link">News</a>
        
        <div class="pl-4">
          <a href="/contact" class="magnetic-btn relative overflow-hidden bg-primary text-white px-6 py-2.5 rounded-full font-semibold text-sm transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-1 block">
            <span class="relative z-10 flex items-center gap-2">
              Contact Us
              <span class="btn-glow absolute inset-0 rounded-full opacity-0 transition-opacity duration-300 pointer-events-none"></span>
            </span>
          </a>
        </div>
      </div>
      
      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-btn" 
        class="md:hidden p-2 text-primary hover:text-secondary transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Mobile Navigation Drawer -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 absolute w-full left-0 shadow-2xl rounded-b-2xl overflow-hidden pb-6 z-40 transform origin-top transition-transform duration-300">
      <div class="px-4 pt-4 pb-4 space-y-2">
        <a href="/" class="mobile-nav-link">Home</a>
        <a href="/about" class="mobile-nav-link">About</a>
        
        <div class="py-3 bg-gray-50 rounded-xl px-2 my-2">
          <p class="px-3 text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Our Services</p>
          <div class="space-y-1">
            {megaMenuServices.map((service) => (
              <a href={service.href} class="flex items-center gap-3 px-3 py-2 text-primary hover:bg-white rounded-lg transition-colors border border-transparent hover:border-gray-100 hover:shadow-sm">
                <div class="w-8 h-8 rounded-full bg-primary/5 flex items-center justify-center">
                  <div class="scale-75">
                    <Fragment set:html={service.icon} />
                  </div>
                </div>
                <div>
                  <span class="block text-sm font-bold">{service.intent}</span>
                  <span class="block text-xs text-gray-500">{service.company}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
        
        <a href="/chairman" class="mobile-nav-link">Chairman</a>
        <a href="/news" class="mobile-nav-link">News</a>
        <a href="/contact" class="mt-4 block w-full text-center bg-primary text-white py-3 rounded-xl font-bold shadow-md hover:bg-secondary transition-colors">Contact Us</a>
      </div>
    </div>
  </nav>
</header>

<style>
  @reference "../styles/global.css";
  .nav-link {
    @apply px-4 py-2 text-primary font-semibold text-sm uppercase tracking-wide transition-all duration-300 relative rounded-md hover:bg-gray-50;
  }
  
  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-1/2 w-0 h-0.5 bg-secondary transition-all duration-300 -translate-x-1/2 opacity-0;
  }
  
  .nav-link:hover::after, .nav-link:focus::after {
    @apply w-3/4 opacity-100;
  }

  .mobile-nav-link {
    @apply block px-4 py-3 text-primary font-bold hover:bg-gray-50 hover:text-secondary rounded-xl transition-colors;
  }

  .btn-glow {
    background: radial-gradient(circle at center, rgba(200, 169, 106, 0.4) 0%, transparent 70%);
  }
  
  .magnetic-btn:hover .btn-glow {
    opacity: 1;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); opacity: 0.5; }
    50% { transform: scale(1.05); opacity: 0.8; }
    100% { transform: scale(0.95); opacity: 0.5; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const header = document.getElementById('main-header');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Scroll effect for header
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-md', 'bg-white/95');
      header?.classList.remove('bg-white/80', 'shadow-sm');
    } else {
      header?.classList.add('bg-white/80', 'shadow-sm');
      header?.classList.remove('shadow-md', 'bg-white/95');
    }
  });

  // Magnetic button effect for desktop
  const magneticButtons = document.querySelectorAll('.magnetic-btn');
  
  magneticButtons.forEach((btn) => {
    if (btn instanceof HTMLElement) {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        // Move the button slightly towards the mouse
        const xMovement = (x - rect.width / 2) * 0.1;
        const yMovement = (y - rect.height / 2) * 0.1;
        
        btn.style.transform = `translate(${xMovement}px, ${yMovement}px) scale(1.02)`;
        
        // Move the glow effect to follow cursor
        const glow = btn.querySelector('.btn-glow') as HTMLElement;
        if (glow) {
          glow.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(200, 169, 106, 0.6) 0%, transparent 70%)`;
        }
      });
      
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = 'translate(0px, 0px) scale(1)';
        const glow = btn.querySelector('.btn-glow') as HTMLElement;
        if (glow) {
          glow.style.background = 'radial-gradient(circle at center, rgba(200, 169, 106, 0.4) 0%, transparent 70%)';
        }
      });
    }
  });
</script>
