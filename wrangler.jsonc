{
	// Cloudflare Workers config for Mallik Group Website (Astro 6 SSR)
	"name": "mallik-group-website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2025-03-20",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"r2_buckets": [
		{
			"bucket_name": "mallik-group-storage",
			"binding": "STORAGE"
		}
	],
	"observability": {
		"enabled": true
	}
}